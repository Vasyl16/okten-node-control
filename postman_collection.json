{
  "info": {
    "name": "AutoRia Clone API - Backend",
    "_postman_id": "b0d7b5a4-0d8b-4c7e-9bd9-6c5c5b9c3e11",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ready-to-import requests for local testing."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "advertId", "value": "" },
    { "key": "brandId", "value": "" },
    { "key": "regionId", "value": "1" },
    { "key": "modelId", "value": "1" },
    { "key": "targetUserId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Sign Up (seller)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/sign-up", "host": ["{{baseUrl}}"], "path": ["auth", "sign-up"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ivan\",\n  \"lastName\": \"Seller\",\n  \"email\": \"ivan.seller@example.com\",\n  \"password\": \"StrongPassword123!\",\n  \"phone\": \"+380123456789\",\n  \"role\": \"seller\"\n}"
        }
      }
    },
    {
      "name": "Auth - Sign In (admin)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/sign-in", "host": ["{{baseUrl}}"], "path": ["auth", "sign-in"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@autoria.local\",\n  \"password\": \"admin123\"\n}"
        }
      }
    },
    {
      "name": "Auth - Sign In (premium seller)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/sign-in", "host": ["{{baseUrl}}"], "path": ["auth", "sign-in"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"premium.seller@autoria.local\",\n  \"password\": \"admin123\"\n}"
        }
      }
    },
    {
      "name": "Catalog - Get Brands (public)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/catalog/brands", "host": ["{{baseUrl}}"], "path": ["catalog", "brands"] }
      }
    },
    {
      "name": "Catalog - Create Brand (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/catalog/brands", "host": ["{{baseUrl}}"], "path": ["catalog", "brands"] },
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mercedes\"\n}" }
      }
    },
    {
      "name": "Catalog - Create Model (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/catalog/brands/{{brandId}}/models", "host": ["{{baseUrl}}"], "path": ["catalog", "brands", "{{brandId}}", "models"] },
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"E-Class\"\n}" }
      }
    },
    {
      "name": "Catalog - Request New Brand (any authenticated)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/catalog/requests/brand", "host": ["{{baseUrl}}"], "path": ["catalog", "requests", "brand"] },
        "body": { "mode": "raw", "raw": "{\n  \"requestedName\": \"Kia\",\n  \"comment\": \"Need this brand in list\"\n}" }
      }
    },
    {
      "name": "Ads - Create Advert (seller/premium seller)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/ads", "host": ["{{baseUrl}}"], "path": ["ads"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"BMW X5 test\",\n  \"description\": \"Clean description\",\n  \"priceOriginal\": 10000,\n  \"currencyOriginal\": \"USD\",\n  \"modelId\": {{modelId}},\n  \"regionId\": {{regionId}}\n}"
        }
      }
    },
    {
      "name": "Ads - List My Adverts (/ads/me/list)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/ads/me/list", "host": ["{{baseUrl}}"], "path": ["ads", "me", "list"] }
      }
    },
    {
      "name": "Ads - Get Advert by Id (public) -> increments views",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/ads/{{advertId}}", "host": ["{{baseUrl}}"], "path": ["ads", "{{advertId}}"] }
      }
    },
    {
      "name": "Ads - Get Advert Stats (premium owner only)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/ads/{{advertId}}/stats", "host": ["{{baseUrl}}"], "path": ["ads", "{{advertId}}", "stats"] }
      }
    },
    {
      "name": "Users - Ban user (admin/manager)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/users/{{targetUserId}}/ban", "host": ["{{baseUrl}}"], "path": ["users", "{{targetUserId}}", "ban"] }
      }
    },
    {
      "name": "Moderation - List Queue",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/moderation/ads", "host": ["{{baseUrl}}"], "path": ["moderation", "ads"] }
      }
    }
  ]
}

